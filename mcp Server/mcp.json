{
  "mcpServers": {
    "deterministic-handoff-system": {
      "type": "stdio",
      "command": "/root/Deterministic-Handoff-System/mcp/server",
      "args": [],
      "env": {
        "VIBE_HOME": "${{ env.VIBE_HOME }}",
        "ACCESS_TOKEN": "${{ secrets.COPILOT_MCP_SENTRY_ACCESS_TOKEN }}",
        "API_KEY_ENV": "${{ secrets.API_KEY_ENV }}",
        "AUTHORIZATION": "${{ secrets.AUTHORIZATION_ }}",
        "DEBUG": "1",
        "LOG_LEVEL": "info",
        "MISTRAL_API_KEY": "${{ secrets.COPILOT_MCP_Mistral_API_KEY }}",
        "OLLAMA": "openai",
        "TRANSPORT": "stdio"
      },
      "timeout": {
        "startup": 15,
        "tool": 120
      },
      "permissions": {
        "tools.fetch_server_get": "always",
        "tools.deterministic_handoff_query": "ask"
      }
    }
  }
}
